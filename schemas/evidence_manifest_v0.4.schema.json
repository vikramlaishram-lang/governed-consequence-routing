{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/vikramlaishram-lang/governed-consequence-routing/schemas/evidence_manifest_v0.4.schema.json",
  "title": "Evidence Manifest v0.4",
  "description": "A local evidence manifest that binds admitted evidence items to one governed proposal and decision envelope.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "evidence_manifest_id",
    "created_at",
    "proposal_id",
    "proposal_hash",
    "normalized_action_hash",
    "policy_hash",
    "evidence_scope",
    "evidence_items",
    "evidence_requirements",
    "admissibility_decision",
    "evidence_manifest_hash"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "evidence_manifest.v0.4"
    },
    "evidence_manifest_id": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "proposal_id": {
      "type": "string",
      "format": "uuid"
    },
    "proposal_hash": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "normalized_action_hash": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "policy_hash": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "evidence_scope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "consequence_class",
        "claim_type",
        "operational_use"
      ],
      "properties": {
        "consequence_class": {
          "type": "string",
          "minLength": 1
        },
        "claim_type": {
          "type": "string",
          "enum": [
            "FACTUAL_CLAIM",
            "RELEASE_READINESS_CLAIM",
            "SECURITY_CLAIM",
            "CLINICAL_CLAIM",
            "FINANCIAL_CLAIM",
            "LEGAL_CLAIM",
            "TOOL_ACTION_CLAIM",
            "OTHER"
          ]
        },
        "operational_use": {
          "type": "string",
          "enum": [
            "INFORMATIONAL_ONLY",
            "INTERNAL_DECISION_SUPPORT",
            "CUSTOMER_FACING",
            "CLINICAL_WORKFLOW",
            "FINANCIAL_WORKFLOW",
            "LEGAL_WORKFLOW",
            "RELEASE_WORKFLOW",
            "PRODUCTION_EXECUTION"
          ]
        }
      }
    },
    "evidence_items": {
      "type": "array",
      "minItems": 0,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "evidence_id",
          "evidence_type",
          "source_type",
          "source_ref",
          "collected_at",
          "content_hash",
          "admissibility_status",
          "relevance"
        ],
        "properties": {
          "evidence_id": {
            "type": "string",
            "minLength": 1
          },
          "evidence_type": {
            "type": "string",
            "enum": [
              "TEST_RESULT",
              "RELEASE_NOTE",
              "SOURCE_DOCUMENT",
              "POLICY_DOCUMENT",
              "SYSTEM_STATE",
              "REVIEW_RECORD",
              "USER_PROVIDED_INPUT",
              "MODEL_OUTPUT",
              "EXTERNAL_SIGNAL",
              "OTHER"
            ]
          },
          "source_type": {
            "type": "string",
            "enum": [
              "LOCAL_FILE",
              "INLINE_FIXTURE",
              "EXTERNAL_URI",
              "SYSTEM_CAPTURE",
              "MANUAL_ENTRY",
              "OTHER"
            ]
          },
          "source_ref": {
            "type": "string",
            "minLength": 1
          },
          "collected_at": {
            "type": "string",
            "format": "date-time"
          },
          "content_hash": {
            "type": "string",
            "pattern": "^sha256:[a-f0-9]{64}$"
          },
          "admissibility_status": {
            "type": "string",
            "enum": [
              "ADMITTED",
              "REJECTED",
              "PENDING"
            ]
          },
          "relevance": {
            "type": "string",
            "enum": [
              "REQUIRED",
              "SUPPORTING",
              "CONTEXTUAL"
            ]
          }
        }
      }
    },
    "evidence_requirements": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "required_evidence_types",
        "minimum_admitted_items"
      ],
      "properties": {
        "required_evidence_types": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "TEST_RESULT",
              "RELEASE_NOTE",
              "SOURCE_DOCUMENT",
              "POLICY_DOCUMENT",
              "SYSTEM_STATE",
              "REVIEW_RECORD",
              "USER_PROVIDED_INPUT",
              "MODEL_OUTPUT",
              "EXTERNAL_SIGNAL",
              "OTHER"
            ]
          },
          "uniqueItems": true
        },
        "minimum_admitted_items": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "admissibility_decision": {
      "type": "string",
      "enum": [
        "SUFFICIENT",
        "INSUFFICIENT",
        "PARTIAL",
        "NOT_REQUIRED"
      ]
    },
    "evidence_manifest_hash": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    }
  }
}
