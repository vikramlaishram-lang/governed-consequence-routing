{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/schemas/governance_record_graph_v1.0.schema.json",
  "title": "Governance Record Graph v1.0",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "graph_id",
    "schema_version",
    "created_at",
    "source_artifacts",
    "verifier_results",
    "nodes",
    "edges",
    "proof_boundary",
    "graph_hash"
  ],
  "properties": {
    "graph_id": {
      "type": "string",
      "format": "uuid"
    },
    "schema_version": {
      "const": "governance_record_graph_v1.0"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "source_artifacts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "artifact_id",
          "artifact_type",
          "path",
          "sha256"
        ],
        "properties": {
          "artifact_id": {
            "type": "string",
            "minLength": 1
          },
          "artifact_type": {
            "enum": [
              "RUNTIME_PROPOSAL",
              "DECISION_ENVELOPE",
              "APPROVAL_TOKEN",
              "REVIEWER_AUTHORITY_MANIFEST",
              "EVIDENCE_MANIFEST",
              "VERIFICATION_BUNDLE",
              "VERIFICATION_RECEIPT",
              "RECEIPT_INDEX",
              "LOCAL_VERIFIER_UI",
              "VERIFIER_OUTPUT"
            ]
          },
          "path": {
            "type": "string",
            "minLength": 1
          },
          "sha256": {
            "type": "string",
            "pattern": "^sha256:[a-f0-9]{64}$"
          }
        }
      }
    },
    "verifier_results": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "verifier_id",
          "verifier_name",
          "status",
          "primary_output",
          "source_artifact_ids"
        ],
        "properties": {
          "verifier_id": {
            "type": "string",
            "minLength": 1
          },
          "verifier_name": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "enum": [
              "PASS",
              "FAIL"
            ]
          },
          "primary_output": {
            "type": "string",
            "minLength": 1
          },
          "source_artifact_ids": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    },
    "nodes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "node_id",
          "node_type",
          "label",
          "source_artifact_ids"
        ],
        "properties": {
          "node_id": {
            "type": "string",
            "minLength": 1
          },
          "node_type": {
            "enum": [
              "RuntimeProposal",
              "Agent",
              "Consequence",
              "DecisionEnvelope",
              "ApprovalToken",
              "ReviewerAuthorityManifest",
              "EvidenceManifest",
              "EvidenceItem",
              "VerificationBundle",
              "VerificationReceipt",
              "ReceiptIndex",
              "VerifierResult",
              "LocalVerifierUI"
            ]
          },
          "label": {
            "type": "string",
            "minLength": 1
          },
          "source_artifact_ids": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    },
    "edges": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "edge_id",
          "edge_type",
          "from_node",
          "to_node",
          "derived_from"
        ],
        "properties": {
          "edge_id": {
            "type": "string",
            "minLength": 1
          },
          "edge_type": {
            "enum": [
              "PROPOSED_BY",
              "NORMALIZED_TO",
              "CLASSIFIED_AS",
              "HAS_EXECUTION_STATUS",
              "HAS_AUTHORIZATION_STATUS",
              "BOUND_TO",
              "AUTHORIZED_BY",
              "SUPPORTED_BY",
              "CONTAINS",
              "VERIFIED_BY",
              "RECEIPT_FOR",
              "INDEXED_IN",
              "DISPLAYED_BY",
              "DERIVED_FROM"
            ]
          },
          "from_node": {
            "type": "string",
            "minLength": 1
          },
          "to_node": {
            "type": "string",
            "minLength": 1
          },
          "derived_from": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "source_artifact_ids",
              "verifier_result_ids"
            ],
            "properties": {
              "source_artifact_ids": {
                "type": "array",
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "verifier_result_ids": {
                "type": "array",
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              }
            }
          }
        }
      }
    },
    "proof_boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "proves",
        "does_not_prove"
      ],
      "properties": {
        "proves": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "does_not_prove": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "graph_hash": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    }
  }
}
